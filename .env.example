# ──────────────────────────────────────────────
#  WatchYourEnergy — environment configuration
#  Copy this file to .env and fill in the values.
#  .env is git-ignored and never committed.
# ──────────────────────────────────────────────

# ── LLM provider ─────────────────────────────
# "gemini" (default) or "anthropic"
LLM_PROVIDER=gemini

# Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Database ──────────────────────────────────
# Path inside the container (matched to the volume mount in docker-compose.yml)
# Change only if you adjust the volume mount path.
DB_PATH=/data/watch_your_energy.db

# ── Server ────────────────────────────────────
# Docker Compose overrides PORT to 8000; Railway sets it automatically.
# You normally do not need to change this.
PORT=8000

# ── CORS ─────────────────────────────────────
# Comma-separated list of additional allowed origins (e.g. a Flutter Web origin).
# Leave empty for local-only use.
ALLOWED_ORIGINS=
