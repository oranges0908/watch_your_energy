# Version control
.git
.gitignore

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache
.mypy_cache

# SQLite data (use a volume in production)
**/*.db
**/*.db-shm
**/*.db-wal

# Frontend build artifacts (source is needed for multi-stage build)
frontend/build/
frontend/.dart_tool/

# Docs
doc/

# Local env
.env
*.env

# OS
.DS_Store

# Script backups
backups/
